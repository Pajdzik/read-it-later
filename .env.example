# Local server
PORT=3055
HOST=0.0.0.0
AUTH_BASE_URL=http://localhost:3055

# GitHub OAuth login
# Create an OAuth app with callback: http://localhost:3055/auth/github/callback
# Keep at least one allowlist setting populated in production.
AUTH_ALLOWED_GITHUB_USERS=your-github-login
GITHUB_OAUTH_CLIENT_ID=your-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# AUTH_SESSION_DAYS=7
# PATCH_READ_BODY_LIMIT_BYTES=4096

# Optional GitHub-backed article storage
# Production deployments with GITHUB_TOKEN should also enable OAuth above.
# STORAGE_MODE=github
# GITHUB_OWNER=your-github-user-or-org
# GITHUB_REPO=your-repo
# GITHUB_BRANCH=main
# GITHUB_ARTICLES_PATH=Articles
# GITHUB_TOKEN=github_pat_...

# Production escape hatches; leave unset unless you intentionally accept the risk.
# ALLOW_UNAUTHENTICATED_GITHUB_WRITES=false
# ALLOW_OPEN_PRODUCTION_AUTH=false
