# Local server
PORT=3055
HOST=0.0.0.0
AUTH_BASE_URL=http://localhost:3055

# GitHub OAuth login
# Create an OAuth app with callback: http://localhost:3055/auth/github/callback
AUTH_ALLOWED_GITHUB_USERS=your-github-login
GITHUB_OAUTH_CLIENT_ID=your-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Optional GitHub-backed article storage
# STORAGE_MODE=github
# GITHUB_OWNER=your-github-user-or-org
# GITHUB_REPO=your-repo
# GITHUB_BRANCH=main
# GITHUB_ARTICLES_PATH=Articles
# GITHUB_TOKEN=github_pat_...
